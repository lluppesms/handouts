# Handouts source: 'local' or 'azure'
VITE_HANDOUTS_SOURCE=local

# Local manifest URL (used when source is 'local')
VITE_MANIFEST_URL=/handouts.json

# Azure Storage configuration (used when source is 'azure')
VITE_AZURE_STORAGE_URL=https://<your-storage-account>.blob.core.windows.net
VITE_AZURE_CONTAINER_NAME=handouts
VITE_AZURE_SAS_TOKEN=
